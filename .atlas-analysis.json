  "keyFeatures": [
    "High-level and low-level API for Epic Online Services integration",
    "Cross-platform multiplayer with lobbies, sessions, and P2P networking",
    "Multiple authentication methods (Epic Games, Steam, Discord, Anonymous)",
    "Achievements, stats, and leaderboards with social features",
    "Voice chat and RTC audio support",
    "Social overlay on Windows with friends and presence",
    "Player data storage and title storage",
    "Ecommerce integration with Epic Games Store",
    "Anti-cheat client and server support",
    "Support for Windows, Linux, Android, macOS, and iOS platforms"
  ],
